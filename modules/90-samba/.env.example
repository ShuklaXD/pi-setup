# Samba credentials. Copy to .env and set a password, then run the module.
#   cp .env.example .env  &&  edit .env
# .env is gitignored — NEVER commit the real password.

# Password for the Samba user "shukks" (used when mapping the drive from Windows).
# This is a SEPARATE Samba password, not your system login.
SMB_PASSWORD=changeme
