# Private Internet Access (PIA) credentials for gluetun.
# Copy this file to `.env` in the same directory and fill in your details.
#   cp .env.example .env  &&  edit .env
# .env is gitignored — NEVER commit real credentials.

# Your PIA OpenVPN username (usually starts with "p", e.g. p1234567) and password.
PIA_USER=p1234567
PIA_PASSWORD=your_pia_password

# PIA region to connect to (e.g. "Singapore", "Netherlands", "Switzerland").
PIA_REGION=Singapore

# Your LAN subnet, so the Deluge web UI stays reachable through the killswitch.
LAN_SUBNET=10.75.12.0/24
